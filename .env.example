# ─── Clés API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Podcast ───────────────────────────────────────────────────────────────
PODCAST_TITLE=LE BUZZER
PODCAST_DESCRIPTION=Le podcast sport quotidien francophone québécois. Résultats, histoires et potins de la LNH, NBA, foot, F1 et MMA en 5 minutes. Les épisodes restent disponibles 7 jours.
PODCAST_BASE_URL=https://www.lebuzzer.com
PODCAST_ARTWORK_URL=https://www.lebuzzer.com/artwork.jpg
PODCAST_AUTHOR=LE BUZZER
PODCAST_OWNER_EMAIL=prestopodcast@gmail.com

# ─── Génération ────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
BRIEFING_DUREE_CIBLE=5
BRIEFING_FENETRE_HEURES=24
SYSTEM_PROMPT_FILE=prompts/system_buzzer_v1.md
SOURCES_FILE=config/sources_buzzer.yaml
EPISODE_TITLE_PREFIX=LE BUZZER — édition du

# ─── TTS ───────────────────────────────────────────────────────────────────
# OpenAI TTS, voix sport-anchor :
#   onyx    (grave, autoritaire, broadcaster classique) — recommandé
#   ash     (expressif, hype, plus jeune)
#   echo    (smooth, friendly)
# Modèles : tts-1 (rapide, $0.015 / 1k chars) ou tts-1-hd (meilleure qualité, $0.030 / 1k chars)
TTS_PROVIDER=openai
TTS_MODEL=tts-1
TTS_VOICE=onyx

# ─── Feed ──────────────────────────────────────────────────────────────────
FEED_KEEP_DAYS=7
FEED_FILE=feed.xml

# ─── Contexte / Stockage ───────────────────────────────────────────────────
CONTEXT_FILE=context.json
AUDIO_PREFIX=
